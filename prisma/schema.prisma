generator client {
  provider      = "prisma-client-js"
  // Valid Prisma 6 targets only (no linux-amd64-openssl-*). Debian slim + ARM64 Coolify:
  // debian-openssl-* covers amd64/arm64 node:bookworm-slim; linux-arm64-* for explicit ARM glibc.
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x"]
}

// Local: DATABASE_URL="file:./dev.db" → SQLite at prisma/dev.db (no server).
// Production MySQL: provider = "mysql", add @db.* types, set DATABASE_URL.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

/// One-time tokens for admin password reset (email link).
model AdminPasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_password_reset_tokens")
}

model BlogPost {
  id                 String   @id
  title              String
  slug               String   @unique
  excerpt            String
  content            String
  category           String
  author             Json
  publishedAt        String   @map("published_at")
  readTime           String   @map("read_time")
  image              String
  imageAlt           String   @map("image_alt")
  metaTitle          String   @map("meta_title")
  metaDescription    String   @map("meta_description")
  metaKeywords       Json     @map("meta_keywords")
  ogTitle            String?  @map("og_title")
  ogDescription      String?  @map("og_description")
  ogImage            String?  @map("og_image")
  twitterTitle       String?  @map("twitter_title")
  twitterDescription String?  @map("twitter_description")
  twitterImage       String?  @map("twitter_image")
  canonicalUrl       String?  @map("canonical_url")
  featured           Boolean  @default(false)
  status             String
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model Category {
  id          String   @id
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model CaseStudy {
  id          String   @id
  title       String
  client      String
  category    String
  description String
  tags        Json
  image       String
  imageAlt    String   @map("image_alt")
  projectUrl  String?  @map("project_url")
  published   Boolean  @default(false)
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("case_studies")
}

model GstInvoiceRecord {
  id        String   @id
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gst_invoice_records")
}

model SiteSetting {
  key   String @id
  value Json

  @@map("site_settings")
}

model LeadSubmission {
  id        String   @id @default(cuid())
  source    String
  name      String?
  email     String
  company   String?
  phone     String?
  message   String?
  consent   Boolean  @default(false)
  pageUrl   String?  @map("page_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("lead_submissions")
}

/// Blog newsletter: double opt-in. Confirmed subscribers have confirmedAt set.
model NewsletterSubscription {
  id           String    @id @default(cuid())
  email        String    @unique
  confirmToken String    @unique @map("confirm_token")
  tokenExpires DateTime  @map("token_expires")
  confirmedAt  DateTime? @map("confirmed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("newsletter_subscriptions")
}

/// Public markdown pages (privacy policy, terms, cookie policy, careers, etc.)
model PublicPage {
  slug      String   @id
  title     String
  bodyMd    String   @map("body_md")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("public_pages")
}

model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  shortDescription String   @map("short_description")
  bodyMd           String   @map("body_md")
  logoUrl          String?  @map("logo_url")
  published        Boolean  @default(true)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("services")
}
