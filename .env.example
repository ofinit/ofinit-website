# 1) Copy this file to ".env" in the project root.
# 2) Run: npx prisma db push && npx prisma db seed
# 3) npm run dev
#
# Default: SQLite (no MySQL/Docker required). Database file: prisma/dev.db

DATABASE_URL="file:./dev.db"

# For MySQL instead: use docker-compose.yml or your host, change prisma/schema.prisma
# datasource to provider = "mysql" and add native @db types back, then e.g.:
# DATABASE_URL="mysql://ofinit:ofinit_secret@127.0.0.1:3306/ofinit_website"

# --- Public URL (Coolify: set BOTH at runtime; pass as Docker build args for NEXT_PUBLIC_* inlining) ---
SITE_URL=https://ofinit.com
NEXT_PUBLIC_SITE_URL=https://ofinit.com

# --- Admin login (after `npx prisma db seed` or Docker entrypoint auto-seed) ---
# Email: admin@ofinit.com
# Password: SEED_ADMIN_PASSWORD at seed time, or admin123 if unset

SEED_ADMIN_PASSWORD=admin123

# SMTP is required in production for Forgot password emails and newsletter confirmations.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# --- Optional: Cloudflare Turnstile (recommended for production spam/bots) ---
# Create a widget at https://dash.cloudflare.com → Turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA...
# TURNSTILE_SECRET_KEY=0x4AAAA...
# If unset, APIs skip Turnstile verification (honeypot + rate limits still apply).
